#!/usr/bin/env bash
# Pre-commit hook — run only the tests for plugins whose files are staged.
# Mirrors pre-push's changed-plugin discovery, but against the index (git diff --cached).
# shared/ changing fans out to every plugin (shared/ is bundled into each).
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

# Top-level dirs touched in the staged change set.
changed_dirs="$(git diff --cached --name-only | sed -n 's#^\([^/]*\)/.*#\1#p' | sort -u)"

node_tests=()       # plugin dirs whose *.test.mjs run via node --test
run_python=0        # watch python tests
run_bundle=0        # tests/bundle-integrity.test.mjs
fanout=0            # shared/ touched -> run everything

has() { printf '%s\n' "$changed_dirs" | grep -qx "$1"; }

# shared/ is bundled into every plugin; tests/ is the cross-cutting bundle check.
if has shared || has tests; then
  fanout=1
fi

if [ "$fanout" -eq 1 ]; then
  node_tests=(takeover rem sharp-review traceme evolve)
  run_python=1
  run_bundle=1
else
  for p in takeover rem sharp-review traceme evolve; do
    has "$p" && node_tests+=("$p") && run_bundle=1
  done
  has watch && { run_python=1; run_bundle=1; }
fi

if [ "${#node_tests[@]}" -eq 0 ] && [ "$run_python" -eq 0 ] && [ "$run_bundle" -eq 0 ]; then
  echo "pre-commit: no plugin tests affected by staged changes — skipping."
  exit 0
fi

selected=()
[ "$run_bundle" -eq 1 ] && selected+=("tests/bundle-integrity.test.mjs")
# shared/ owns the canonical modules bundled into every plugin — run its own suite when touched.
{ has shared || has tests; } && selected+=("shared/tests/*.test.mjs")
for p in "${node_tests[@]}"; do
  selected+=("$p/tests/*.test.mjs")
done

failed=0
# Unset GIT_* so tests that spin up temp git repos (e.g. check-docs CLI) don't inherit
# this commit's index/dir — git exports GIT_DIR/GIT_INDEX_FILE into hooks, and those tests
# would otherwise operate on the real repo and fail spuriously. Same guard as watch's
# python tests below.
for glob in "${selected[@]}"; do
  if ! env -u GIT_DIR -u GIT_INDEX_FILE -u GIT_WORK_TREE -u GIT_PREFIX \
          -u GIT_OBJECT_DIRECTORY -u GIT_COMMON_DIR \
          node --test $glob > /dev/null 2>&1; then
    echo "FAIL: $glob"
    failed=1
  fi
done

if [ "$run_python" -eq 1 ]; then
  # Pick a Python that actually RUNS. `command -v python` alone matches the Windows Store
  # alias shim (…/WindowsApps/python.exe), which passes the lookup but then errors at
  # runtime ("Python was not found") and exits non-zero — turning a missing interpreter
  # into a spurious test failure. Require a working `--version`, and fall back to
  # python3/py for cross-platform robustness.
  py=""
  for cand in python python3 py; do
    if command -v "$cand" > /dev/null 2>&1 && "$cand" --version > /dev/null 2>&1; then
      py="$cand"; break
    fi
  done
  if [ -n "$py" ]; then
    # Unset GIT_* so watch's git-based tests don't inherit this commit's index/dir
    # (git exports GIT_DIR/GIT_INDEX_FILE into hooks; tests that shell out to git in
    # temp repos would otherwise operate on the real repo and fail spuriously).
    if ! env -u GIT_DIR -u GIT_INDEX_FILE -u GIT_WORK_TREE -u GIT_PREFIX \
            -u GIT_OBJECT_DIRECTORY -u GIT_COMMON_DIR \
            "$py" -m unittest discover watch/tests/ > /dev/null 2>&1; then
      echo "FAIL: watch/tests (python)"
      failed=1
    fi
  else
    echo "pre-commit: no working python — skipping watch tests."
  fi
fi

if [ "$failed" -ne 0 ]; then
  echo ""
  echo "Tests failed. Run manually:"
  for glob in "${selected[@]}"; do
    echo "  node --test $glob"
  done
  [ "$run_python" -eq 1 ] && echo "  python -m unittest discover watch/tests/"
  exit 1
fi

echo "All affected plugin tests passed."
