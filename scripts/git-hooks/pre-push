#!/usr/bin/env bash
# Pre-push: auto-bump marketplace version if any plugin changed.
set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"

if git describe --exact-match HEAD 2>/dev/null; then
  exit 0
fi

BUMPED=false

while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    continue
  fi

  range=""
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    range="$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi

  # Only bump if a plugin directory actually changed
  for plugin_dir in "$REPO_ROOT"/*/; do
    name="$(basename "$plugin_dir")"
    # Skip non-plugin dirs
    [ -f "$plugin_dir/.claude-plugin/plugin.json" ] || continue

    if [ -n "$(git diff --name-only "$range" -- "$name/")" ]; then
      BUMPED=true
      break
    fi
  done

  [ "$BUMPED" = true ] && break
done

if [ "$BUMPED" = true ]; then
  new_ver=$(bash "$REPO_ROOT/scripts/bump-version.sh")
  git commit --amend --no-edit --no-verify -q
  git tag -a "v${new_ver}" -m "Release v${new_ver}"
  echo "pre-push: tagged v${new_ver}"
fi

exit 0
