{
  "description": "TraceMe observability hooks — pull cross-device snapshots at session start; at session end, scan transcripts for token/tool/cost data and push an encrypted daily snapshot.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/traceme-hook.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/traceme-hook.js\"",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/traceme-hook.js\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
