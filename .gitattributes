# Normalize line endings: store and check out text as LF on every platform.
# This stops core.autocrlf=true from rewriting CRLF on Windows checkout (the
# "LF will be replaced by CRLF" warnings) and keeps rem's line-by-line task
# parsing stable regardless of who commits.
* text=auto eol=lf

# Explicit text types (defensive; covered by the rule above).
*.mjs  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.sh   text eol=lf
*.py   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Binaries: never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
